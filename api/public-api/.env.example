# Environment variables for local development.
# In production these are injected by the nextjs-config ConfigMap.
# DO NOT commit real values — this file is for local dev only.

# AWS region (injected from ConfigMap in cluster)
AWS_DEFAULT_REGION=eu-west-1

# DynamoDB table and GSI names (resolve from SSM for local dev)
DYNAMODB_TABLE_NAME=your-content-table-name
DYNAMODB_GSI1_NAME=gsi1-status-date
DYNAMODB_GSI2_NAME=gsi2-tag-date

# Server port (default: 3001)
PORT=3001

# For local dev, AWS credentials are resolved from ~/.aws/credentials.
# In cluster, credentials come from IMDS (EC2 Instance Profile) — no config needed.
