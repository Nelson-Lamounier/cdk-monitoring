{
    "name": "@repo/api",
    "version": "0.1.0",
    "private": true,
    "description": "BFF API services — admin-api (write-heavy, Cognito-protected).",
    "scripts": {
        "test": "yarn workspaces foreach --all --include '@repo/admin-api' run test",
        "test:watch": "yarn workspaces foreach --all --include '@repo/admin-api' --parallel run test:watch",
        "test:coverage": "yarn workspaces foreach --all --include '@repo/admin-api' run test:coverage",
        "build": "yarn workspaces foreach --all --include '@repo/admin-api' run build",
        "typecheck": "yarn workspaces foreach --all --include '@repo/admin-api' run typecheck",
        "lint": "yarn workspaces foreach --all --include '@repo/admin-api' run lint"
    }
}
